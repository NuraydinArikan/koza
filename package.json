{
  "name": "koza-platform",
  "version": "1.0.0",
  "description": "Anonymous Peer-to-Peer Therapy & Support Network",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run --reporter=verbose src/**/*.unit.test.ts",
    "test:integration": "vitest --run --reporter=verbose src/**/*.integration.test.ts",
    "test:security": "vitest --run --reporter=verbose src/**/*.security.test.ts",
    "test:smoke": "cypress run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,css}'",
    "type-check": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high",
    "db:migrate": "node scripts/migrate-db.js",
    "db:seed": "node scripts/seed-db.js",
    "db:rollback": "node scripts/rollback-db.js",
    "maintenance:purge-sessions": "node scripts/maintenance/purge-sessions.js",
    "maintenance:delete-expired-messages": "node scripts/maintenance/delete-expired-messages.js",
    "maintenance:process-deletions": "node scripts/maintenance/process-deletions.js",
    "maintenance:verify-purge": "node scripts/maintenance/verify-purge.js",
    "deploy:staging": "firebase deploy --project=koza-staging",
    "deploy:production": "firebase deploy --project=koza-production",
    "deploy:rollback": "firebase hosting:channels:delete live --project=koza-production",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.2.0",
    "@supabase/supabase-js": "^2.37.0",
    "firebase": "^10.4.0",
    "zustand": "^4.4.1",
    "peerjs": "^1.5.2",
    "simple-peer": "^9.11.1",
    "web-audio-api": "^0.2.2",
    "@tensorflow/tfjs": "^4.10.0",
    "@tensorflow-models/mediapipe-pose": "^5.5.0",
    "@mediapipe/tasks-vision": "^0.10.0",
    "openai": "^4.11.1",
    "uuid": "^9.0.0",
    "axios": "^1.5.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "vite": "^4.4.9",
    "vitest": "^0.34.2",
    "@vitest/ui": "^0.34.2",
    "@vitest/coverage-v8": "^0.34.2",
    "cypress": "^13.3.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.4",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1",
    "semgrep": "^1.45.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "therapy",
    "peer-support",
    "anonymous",
    "mental-health",
    "webrtc",
    "privacy"
  ],
  "author": "Koza Team",
  "license": "AGPL-3.0-only"
}
